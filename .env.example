AUTOESSAY_ENV=local
AUTOESSAY_BASE_URL=http://127.0.0.1:3000
AUTOESSAY_DATA_DIR=./data
AUTOESSAY_DOMAIN_DIR=./domains
DATABASE_URL=sqlite:///./autoessay.sqlite3
REDIS_URL=redis://127.0.0.1:6379/0

# OpenAI-compatible LLM gateway. Use placeholders here; put real
# tokens only in an untracked .env file or your deployment secret store.
ONE_API_BASE_URL=https://llm-gateway.example.invalid
ONE_API_TOKEN=replace-with-provider-token
ONE_API_MODEL=replace-with-model-id
AUTOESSAY_LLM_PROVIDERS=
AUTOESSAY_LLM_REQUEST_TIMEOUT_SECONDS=180

# Optional service integrations.
APPLESEED_MEMORY_URL=http://127.0.0.1:8010
APPLESEED_MEMORY_TOKEN=
APPLESEED_ORCHESTRATOR_BASE_URL=
APPLESEED_ORCHESTRATOR_TOKEN=
APPLESEED_ROUNDTABLE_BASE_URL=
APPLESEED_ROUNDTABLE_TOKEN=
ORIGINALITY_API_KEY=
GPTZERO_API_KEY=
COPYLEAKS_EMAIL=
COPYLEAKS_API_KEY=

# Auth/session. Generate a strong unique value for non-local use.
AUTOESSAY_SESSION_SECRET=replace-with-32-byte-random
AUTOESSAY_AUTH_BYPASS=0
AUTOESSAY_INITIAL_ADMIN_USERNAME=
AUTOESSAY_INITIAL_ADMIN_PASSWORD_HASH=
AUTOESSAY_INITIAL_ADMIN_DISPLAY_NAME=Administrator

LOG_LEVEL=INFO
AUTOESSAY_IMAGE_TAG=local
AUTOESSAY_RQ_QUEUE=autoessay
MANUSCRIPT_DEFAULT_MODE=express

# Express mode.
AUTOESSAY_EXPRESS_TOKEN_CAP=100000
AUTOESSAY_EXPRESS_TIMEOUT_SECONDS=300
AUTOESSAY_EXPRESS_MANUSCRIPT_MAX_TOKENS=60000
AUTOESSAY_EXPRESS_AUDIT_MAX_TOKENS=8000
AUTOESSAY_EXPRESS_MODEL=replace-with-model-id

# Local/CI stubs. Set these to 0 when your provider configuration is ready.
AUTOESSAY_PROPOSAL_STUB=1
AUTOESSAY_SCOUT_STUB=1
AUTOESSAY_CANONICAL_MINING_STUB=1
AUTOESSAY_CURATOR_STUB=1
AUTOESSAY_CURATOR_RERANK_STUB=1
AUTOESSAY_SYNTHESIZER_STUB=1
AUTOESSAY_DRAFTER_STUB=1
AUTOESSAY_STYLIST_STUB=1
AUTOESSAY_FINAL_REWRITE_STUB=1
AUTOESSAY_CRITIC_STUB=1
AUTOESSAY_INTEGRITY_STUB=1
AUTOESSAY_SAFETY_GATE_STUB=1
AUTOESSAY_KERNEL_SUGGEST_STUB=1
AUTOESSAY_FRAMEWORK_LENS_STUB=1
AUTOESSAY_TENSION_EXTRACTION_STUB=1
AUTOESSAY_MEMORY_READ=0
AUTOESSAY_OPENALEX_STUB=1
AUTOESSAY_CNKI_STUB=1
AUTOESSAY_LOCAL_DEDUP_STUB=1
AUTOESSAY_ALLOW_PRIOR_TEXT=0
